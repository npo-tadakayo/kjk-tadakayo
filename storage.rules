rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /sessions/{sessionId}/photos/{photoId} {
      allow read, write: if request.auth != null && request.auth.token.email.matches('.*@tadakayo[.]jp$');
    }
    match /reports/{reportId} {
      allow read, write: if request.auth != null && request.auth.token.email.matches('.*@tadakayo[.]jp$');
    }
    match /documents/{caseId}/{fileId} {
      allow read, write: if request.auth != null && request.auth.token.email.matches('.*@tadakayo[.]jp$');
    }
  }
}
