rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isTadakayoStaff() {
      return isAuthenticated() && request.auth.token.email.matches('.*@tadakayo[.]jp$');
    }
    // 認定事業所パートナー: partners/{email} が存在し active==true
    function isPartner() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/partners/$(request.auth.token.email))
        && get(/databases/$(database)/documents/partners/$(request.auth.token.email)).data.active == true;
    }

    // 商品マスタ: 認証済みなら閲覧可（パートナーがカタログ参照）／編集はタダカヨのみ
    match /products/{sku} {
      allow read: if isAuthenticated();
      allow write: if isTadakayoStaff();
    }

    // パートナー名簿: 本人は自分の登録のみ閲覧可／管理はタダカヨ
    match /partners/{email} {
      allow read: if isTadakayoStaff() || (isAuthenticated() && request.auth.token.email == email);
      allow write: if isTadakayoStaff();
    }

    // 認定事業所からの発注（受注）: 本人は作成＋自分の分のみ閲覧／タダカヨは全件
    match /partnerOrders/{id} {
      allow create: if isPartner()
        && request.resource.data.partnerEmail == request.auth.token.email;
      allow read: if isTadakayoStaff()
        || (isPartner() && resource.data.partnerEmail == request.auth.token.email);
      allow update, delete: if isTadakayoStaff();
    }

    // 上記以外（案件・事業所・対応記録・在庫・発注・出荷・カウンタ等）はタダカヨのみ
    match /{document=**} {
      allow read, write: if isTadakayoStaff();
    }
  }
}
