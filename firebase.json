{
  "hosting": [
    {
      "target": "lp",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".gitignore",
        ".git/**",
        ".claude/**",
        "CNAME",
        "deploy.sh",
        "*.md",
        "*.py",
        "PRICING.md",
        "ABサークル様資料/**",
        "admin/**",
        "functions/**"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
        },
        {
          "source": "**/*.@(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        }
      ]
    },
    {
      "target": "admin",
      "public": "admin",
      "ignore": [
        "firebase.json",
        ".firebaserc"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "headers": [
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
        },
        {
          "source": "**/*.@(css|js)",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
        }
      ]
    }
  ],
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
